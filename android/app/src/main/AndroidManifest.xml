<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network access for the WebView and API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Show our own local notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Run a foreground service (keeps notification listener alive) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Vibrate device when an opportunity is found -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Restart the listener service after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpportUnity"
        android:usesCleartextTraffic="false">

        <!-- Splash screen → grants permission if needed → goes to MainActivity -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.OpportUnity.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main activity: full-screen WebView + deep-link handler -->
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Deep link: opportunity://extract?text=... (from notification taps) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:host="extract"
                    android:scheme="opportunity" />
            </intent-filter>
        </activity>

        <!--
             NotificationListenerService — reads WhatsApp and Telegram notifications.
             Note: Does NOT use foregroundServiceType (that attribute is only for Service subclasses).
             The BIND_NOTIFICATION_LISTENER_SERVICE permission is set on the <service>, NOT in <uses-permission>.
        -->
        <service
            android:name=".OpportunityNotificationService"
            android:exported="true"
            android:label="@string/notification_service_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!--
             Foreground service — keeps the notification listener alive on aggressive OEMs.
             foregroundServiceType="specialUse" is required when targeting API 34+.
        -->
        <service
            android:name=".NotificationForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Restart foreground service after device boots -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
