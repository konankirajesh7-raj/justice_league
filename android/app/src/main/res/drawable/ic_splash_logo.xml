<?xml version="1.0" encoding="utf-8"?>
<!--
  Vector drawable: bell icon for splash screen.
  NOTE: Android vector drawables only support <path> and <group> elements.
  No <circle>, <rect>, or <ellipse> — those are SVG-only.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
