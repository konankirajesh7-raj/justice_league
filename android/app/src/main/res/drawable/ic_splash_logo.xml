        android:fillColor="#6366F1"
        android:pathData="M54,20 A34,34 0 1 0 54,88 A34,34 0 1 0 54,20 Z" />

    <!-- Bell body (white) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,36 C52,36 50,37 49,38 C46,40 44,44 44,48 L44,58 L41,61 L41,63 L67,63 L67,61 L64,58 L64,48 C64,44 62,40 59,38 C58,37 56,36 54,36 Z" />

    <!-- Bell bottom clapper arch -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M50,63 A4,4 0 0 0 58,63 Z" />

    <!-- Bell top stem -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M52,34 A2,2 0 1 0 56,34 A2,2 0 1 0 52,34 Z" />

</vector>
